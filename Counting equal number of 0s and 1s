#include <iostream>
#include <vector>
#include <unordered_map>
using namespace std;

int main() {
    int n;
    cin >> n;

    vector<int> arr(n);

    for(int i = 0; i < n; i++) {
        cin >> arr[i];
    }

    unordered_map<int, int> mp;
    mp[0] = 1;

    int sum = 0;
    long long count = 0;

    for(int i = 0; i < n; i++) {

        if(arr[i] == 0)
            sum += -1;
        else
            sum += 1;

        count += mp[sum];
        mp[sum]++;
    }

    cout << count;

    return 0;
}
